VITE_API_URL=https://jeevan-health-api.onrender.com/api

# Google OAuth — required for Sign in with Google
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized JS origins: http://localhost:3000, https://jeevanhealthcare.com
VITE_GOOGLE_CLIENT_ID=

# Analytics (optional — leave empty to skip)
VITE_GTM_ID=
VITE_GA4_ID=
VITE_META_PIXEL_ID=

# Auth note: phone OTP + email OTP are handled by the API.
# No SMS/email keys needed on the frontend — only VITE_API_URL + Google client ID.
